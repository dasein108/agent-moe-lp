# Merchant Moe (Mantle) farming bot configuration.

# Network
MANTLE_RPC_URL=https://rpc.mantle.xyz
CHAIN_ID=5000

# WMNT/USDT Merchant Moe Liquidity Book pool (binStep 15)
POOL_ADDRESS=0xf6c9020c9e915808481757779edb53daceae2415
WMNT_ADDRESS=0x78c1b0c915c4faa5fffa6cabf0219da63d7f4cb8
USDT_ADDRESS=0x201EBa5CC46D216Ce6DC03F6a759e8E766e956aE
MOE_FACTORY_ADDRESS=0xa6630671775c4EA2743840F9A5016dCf2A104054
MOE_ROUTER_ADDRESS=0x013e138EF6008ae5FDFDE29700e3f2Bc61d21E3a

# Strategy parameters
BIN_COUNT=10
SLIPPAGE_BPS=100
ID_SLIPPAGE=5
MIN_POSITION_SIZE_USDT=10
# 0 means auto-detect the pool deployment block and start scanning there.
LOG_SCAN_START_BLOCK=0
LOG_SCAN_CHUNK_SIZE=100

# Gas / budget (Mantle L2 gas is cheap, so a small native MNT reserve suffices)
GAS_RESERVE_MNT=2
MAX_BUDGET_PCT=0.80
MNT_MIN_BALANCE=0

# Optional wallet (otherwise loaded from wallet.json)
WALLET_ADDRESS=
PRIVATE_KEY=
WALLET_FILE=wallet.json

# Notifications
NOTIFICATIONS_ENABLED=true

# Telegram Notifications (optional)
TELEGRAM_NOTIFICATIONS_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Logging / debugging
MOE_DEBUG=false
MOE_LOG_LEVEL=INFO
MOE_LOG_FILE=

# LP Distribution Shape Configuration
# Controls how liquidity is distributed across bins
# Options: uniform, slope, curve, custom
DISTRIBUTION_SHAPE=uniform
# For slope distribution: ascending, descending, peak, valley
SLOPE_DIRECTION=ascending
# Linear gradient multiplier (0.1-5.0)
SLOPE_STEEPNESS=1.0
# For curve distribution: exponential, logarithmic, bell, u_curve
CURVE_TYPE=exponential
# Curve steepness parameter (0.1-10.0)
CURVE_EXPONENT=2.0
# Custom distribution: comma-separated weights (e.g., "0.1,0.2,0.3,0.2,0.2")
CUSTOM_DISTRIBUTION=

# Portfolio Allocation Configuration
# Target MNT ratio in basis points (1000=10%, 5000=50%, 9000=90%)
TARGET_MNT_RATIO_BPS=5000
